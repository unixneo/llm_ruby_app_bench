<% page_title = case @challenge&.name
when "Vehicle Routing Problem" then "VRP Attempts"
when "Assignment Problem" then "Assignment Attempts"
when "Max Flow Problem" then "Max Flow Attempts"
else "TSP Attempts"
end %>
<% attempts_path_for_scope = case @challenge&.name
when "Vehicle Routing Problem" then vrp_attempts_path
when "Assignment Problem" then assignment_attempts_path
when "Max Flow Problem" then max_flow_attempts_path
else attempts_path
end %>
<% content_for :title, page_title %>

<div class="page-header">
  <div>
    <h1 class="page-title"><%= page_title %></h1>
    <p class="page-subtitle">Codex Ruby candidate results compared with OR-Tools gem references.</p>
  </div>
  <%= link_to "Back to algorithms", root_path, class: "btn btn-secondary" %>
</div>

<% if @algorithm_versions.any? %>
  <section class="card">
    <div class="card-header">
      <h2 class="card-title">Algorithm Versions</h2>
      <%= link_to "All attempts", attempts_path_for_scope, class: "btn btn-secondary" %>
    </div>

    <div class="filter-row">
      <% @algorithm_versions.each do |algorithm_version| %>
        <%= link_to algorithm_version, "#{attempts_path_for_scope}?algorithm_version=#{ERB::Util.url_encode(algorithm_version)}", class: "btn btn-secondary" %>
      <% end %>
    </div>
  </section>
<% end %>

<% if @attempts.any? %>
  <section class="attempt-grid">
    <% @attempts.each do |attempt| %>
      <article class="attempt-card">
        <div class="card-header">
          <div>
            <h2 class="card-title"><%= link_to attempt.fixture_name, attempt.route_path_name == :vrp ? vrp_attempt_path(attempt) : (attempt.route_path_name == :assignment ? assignment_attempt_path(attempt) : (attempt.route_path_name == :max_flow ? max_flow_attempt_path(attempt) : attempt_path(attempt))) %></h2>
            <p class="muted-line"><%= attempt.prompt_id %> · <%= attempt.challenge.name %> · <%= attempt.algorithm_version %> · <%= attempt.reference_version %></p>
          </div>
          <span class="badge <%= attempt.status_badge_class %>"><%= attempt.status_label %></span>
        </div>

        <div class="metric-grid">
          <div class="metric-row">
            <div class="metric-label">Algorithm Version</div>
            <div class="metric-value"><%= attempt.algorithm_version %></div>
          </div>
          <div class="metric-row">
            <div class="metric-label">Reference Version</div>
            <div class="metric-value"><%= attempt.reference_version %></div>
          </div>
          <div class="metric-row">
            <div class="metric-label"><%= attempt.distance_difference_label %></div>
            <div class="metric-value"><%= number_with_precision(attempt.difference, precision: 12, strip_insignificant_zeros: true) %></div>
          </div>
          <div class="metric-row">
            <div class="metric-label">Status</div>
            <div class="metric-value"><%= attempt.status_label %></div>
          </div>
          <div class="metric-row">
            <div class="metric-label">PI Interpretation</div>
            <div class="metric-value"><%= attempt.interpretation&.classification&.humanize || "Pending" %></div>
          </div>
        </div>

        <%= link_to "Review comparison", attempt.route_path_name == :vrp ? vrp_attempt_path(attempt) : (attempt.route_path_name == :assignment ? assignment_attempt_path(attempt) : (attempt.route_path_name == :max_flow ? max_flow_attempt_path(attempt) : attempt_path(attempt))), class: "btn btn-primary" %>
      </article>
    <% end %>
  </section>
<% else %>
  <section class="card">
    <h2 class="card-title">No attempts recorded</h2>
    <p class="muted-line">Run the seeds to create attempt records.</p>
  </section>
<% end %>
